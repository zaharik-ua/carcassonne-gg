PORT=3100
NODE_ENV=development

# Comma-separated frontend origins allowed to call this API with credentials.
FRONTEND_ORIGIN=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5500,http://127.0.0.1:5500

# Public site URL used in redirects and response links.
SITE_BASE_URL=http://localhost:8080

# Use a long random value in real projects.
SESSION_SECRET=replace_with_long_random_string_at_least_32_chars

# Google Cloud OAuth Web application credentials.
GOOGLE_CLIENT_ID=replace_with_google_client_id
GOOGLE_CLIENT_SECRET=replace_with_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3100/auth/google/callback

# SQLite database path, relative to this server folder unless absolute.
DB_PATH=./data/app.sqlite

# In production with cross-site frontend/API domains, use:
# COOKIE_SAME_SITE=none
# COOKIE_SECURE=true
COOKIE_SAME_SITE=lax
COOKIE_SECURE=false

# Optional comma-separated list. Matching users become admins on login.
ADMIN_EMAILS=
