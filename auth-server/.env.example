PORT=3100
FRONTEND_ORIGIN=https://carcassonne.gg
SESSION_SECRET=replace_with_long_random_string
GOOGLE_CLIENT_ID=replace_with_google_client_id
GOOGLE_CLIENT_SECRET=replace_with_google_client_secret
GOOGLE_CALLBACK_URL=https://api.carcassonne.com.ua/auth/google/callback
DB_PATH=./data/auth.sqlite
NODE_ENV=production
COOKIE_SAME_SITE=none
COOKIE_SECURE=true
SITE_BASE_URL=https://carcassonne.gg

# BGA match updates
BGA_EMAIL=replace_with_bga_email
BGA_PASSWORD=replace_with_bga_password
CHROME_BINARY_PATH=/usr/bin/chromium
CHROMEDRIVER_PATH=/usr/bin/chromedriver
BGA_HTTP_WORKERS=6
BGA_HTTP_TIMEOUT_SECONDS=20
BGA_HTTP_MIN_INTERVAL_MS=250
BGA_TOKEN_TTL_SECONDS=86400
MATCH_UPDATE_BATCH_SIZE=20
MATCH_UPDATE_TARGETS=ongoing,empty_finished
MATCH_UPDATE_LIMIT=100

# BGA player Elo updates
PLAYER_ELO_BATCH_SIZE=80
PLAYER_ELO_HTTP_TIMEOUT_SECONDS=20
PLAYER_ELO_MIN_INTERVAL_MS=250
PLAYER_ELO_LIMIT=100
