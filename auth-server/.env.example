PORT=3100
FRONTEND_ORIGIN=https://carcassonne.gg
SESSION_SECRET=replace_with_long_random_string
GOOGLE_CLIENT_ID=replace_with_google_client_id
GOOGLE_CLIENT_SECRET=replace_with_google_client_secret
GOOGLE_CALLBACK_URL=https://api.carcassonne.com.ua/auth/google/callback
DB_PATH=./data/auth.sqlite
NODE_ENV=production
COOKIE_SAME_SITE=none
COOKIE_SECURE=true
SITE_BASE_URL=https://carcassonne.gg

# Google Sheets sync (optional)
GOOGLE_SHEETS_SPREADSHEET_ID=replace_with_google_spreadsheet_id
GOOGLE_SHEETS_MATCHES_SHEET=matches
GOOGLE_SHEETS_LINEUPS_SHEET=lineups
GOOGLE_SERVICE_ACCOUNT_EMAIL=service-account@project-id.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
